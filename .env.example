# API Key for Claude. It will be the Demo's LLM with custom prompts/func for each different agent. It will also drive the RAG
# server-only; the SDK is imported ONLY in lib/ai/client.ts + API routes — never reaches the client bundle.
ANTHROPIC_API_KEY=
# Alias for ANTHROPIC_API_KEY, checked as a fallback. Use it in managed sandboxes
# (e.g. claude.ai cloud-environment variables) if they reserve the canonical name.
# FAHEEM_ANTHROPIC_KEY=

# live | cached | auto. Leave UNSET to use the smart default (auto when a key is
# present, cached when it isn't). Or launch a mode explicitly with the npm scripts:
#   npm run start:cache | start:auto | start:live   (and dev:cache | dev:auto | dev:live)
# Runtime override on stage: the ⌘. overlay sets the "faheem_mode" cookie, which wins over everything.
FAHEEM_MODE=

# Main analyst model. Default "claude-opus-4-8".
FAHEEM_MODEL=claude-opus-4-8

# Prompt-improver model. Default "claude-haiku-4-5".
FAHEEM_IMPROVE_MODEL=claude-haiku-4-5

# Forwarded to the API's output_config effort.
FAHEEM_EFFORT=

# "1" persists every live response as a CacheEntry (rehearsal recording).
FAHEEM_RECORD=

# auto-mode first-token timeout in ms before falling back to cache. Default 10000.
FAHEEM_TIMEOUT_MS=10000

# ── Internal/test knobs — leave unset for normal runs ──
# Cached-replay pacing between text deltas in ms. Default 30; tests set 0.
FAHEEM_REPLAY_DELAY_MS=
# Delay in ms between choreographed agent-stage events. Default 500; tests set 0.
FAHEEM_STAGE_STEP_MS=
# Override the golden-cache directory (default data/demo-cache; tests use a temp dir).
FAHEEM_CACHE_DIR=
# Override the audit-log path (default data/audit-log.json; tests use a temp file).
FAHEEM_AUDIT_PATH=


# -- API LIVE --
SAHMAK_API_KEY=sekret