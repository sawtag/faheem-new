# API Key for Claude. It will be the Demo's LLM with custom prompts/func for each different agent. It will also drive the RAG
# server-only; the SDK is imported ONLY in lib/ai/client.ts + API routes — never reaches the client bundle.
ANTHROPIC_API_KEY=

# live | cached | auto — runtime override: cookie "faheem_mode" wins over this env var.
FAHEEM_MODE=cached

# Main analyst model. Default "claude-opus-4-8".
FAHEEM_MODEL=claude-opus-4-8

# Prompt-improver model. Default "claude-haiku-4-5".
FAHEEM_IMPROVE_MODEL=claude-haiku-4-5

# Forwarded to the API's output_config effort.
FAHEEM_EFFORT=

# "1" persists every live response as a CacheEntry (rehearsal recording).
FAHEEM_RECORD=

# auto-mode first-token timeout in ms before falling back to cache. Default 10000.
FAHEEM_TIMEOUT_MS=10000
