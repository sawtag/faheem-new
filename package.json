{
  "name": "faheem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:cache": "FAHEEM_MODE=cached next dev",
    "dev:auto": "FAHEEM_MODE=auto next dev",
    "dev:live": "FAHEEM_MODE=live next dev",
    "build": "next build",
    "start": "next start",
    "start:cache": "FAHEEM_MODE=cached next start",
    "start:auto": "FAHEEM_MODE=auto next start",
    "start:live": "FAHEEM_MODE=live next start",
    "check": "tsc --noEmit && eslint . && prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:data": "tsx scripts/validate-data.ts",
    "build:sample-template": "tsx scripts/build-sample-template.ts",
    "verify": "npm run check && npm run test && npm run validate:data"
  },
  "dependencies": {
